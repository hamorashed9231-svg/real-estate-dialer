# =====================================================================
# PROPDIAL - ENVIRONMENT VARIABLES CONFIGURATION TEMPLATE (.env.example)
# =====================================================================

# Server Configuration
PORT=5000
NODE_ENV=development

# Database Setup (PostgreSQL via Prisma)
# Use "postgresql://postgres:password123@localhost:5432/propdial?schema=public" for local development
# Use "postgresql://postgres:password123@postgres:5432/propdial?schema=public" inside docker-compose
DATABASE_URL=postgresql://postgres:password123@localhost:5432/propdial?schema=public

# Redis Connection (Bull Queue & Agent Status Caching)
# Use "redis://localhost:6379" for local development
# Use "redis://redis:6379" inside docker-compose
REDIS_URL=redis://localhost:6379

# JWT Secrets (Authentication & Refresh Tokens)
JWT_SECRET=your_jwt_access_secret_key_change_me_in_production
JWT_REFRESH_SECRET=your_jwt_refresh_secret_key_change_me_in_production

# Twilio Integration (VoIP WebRTC & Calling Capabilities)
# ⚠️ REQUIRED - Fill with your Twilio Console credentials
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_TWIML_APP_SID=
TWILIO_API_KEY=
TWILIO_API_SECRET=
TWILIO_NUMBER=

# TCPA Compliance & DNC scrubbing API Key
# ⚠️ REQUIRED - e.g. DNC.com, Telnyx or custom providers
DNC_API_KEY=

# CRM Integration Keys (Stubs)
# ⚠️ OPTIONAL - Fill keys if CRM sync is enabled
HUBSPOT_API_KEY=
SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=
GHL_API_KEY=
FUB_API_KEY=
